# ============================================================
# URBAN CORTEX AI – Root Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.
# ============================================================

# ─── APPLICATION ──────────────────────────────────────────────
APP_NAME=UrbanCortexAI
APP_ENV=development                   # development | staging | production
DEBUG=true                            # true | false

# ─── BACKEND ──────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── FRONTEND ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/api/v1/ws/live

# ─── FIREBASE SERVICE ACCOUNT (Backend – ENV-BASED) ──────────
# These values come from your Firebase service account JSON.
# Copy each field from the JSON into the corresponding variable.
# ⚠️ No JSON file is used at runtime.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your-key-here...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_ID=000000000000000000000

# ─── FIREBASE CLIENT CONFIG (Frontend) ───────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxx

# ─── IOT SIMULATOR ───────────────────────────────────────────
IOT_SIMULATOR_BASE_URL=https://urban-simulator.onrender.com
IOT_SYNC_INTERVAL_SECONDS=60          # How often to poll the IoT simulator
IOT_SYSTEM_API_KEY=your-iot-system-api-key   # API key for POST /bins/update-from-iot

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_PUBLIC=60                  # requests/minute for public endpoints
RATE_LIMIT_CITIZEN=100                # requests/minute for citizen endpoints
RATE_LIMIT_ADMIN=200                  # requests/minute for admin endpoints
RATE_LIMIT_IOT=300                    # requests/minute for IoT ingestion

# ─── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json                       # json | text

# ─── DOCKER ───────────────────────────────────────────────────
DOCKER_BACKEND_IMAGE=urban-cortex-ai-backend
DOCKER_BACKEND_TAG=latest

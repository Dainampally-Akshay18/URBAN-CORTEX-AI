# ============================================================
# URBAN CORTEX AI – Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env to version control.
# ============================================================

# ─── APPLICATION ──────────────────────────────────────────────
APP_NAME=UrbanCortexAI
APP_ENV=development
DEBUG=true

# ─── SERVER ───────────────────────────────────────────────────
BACKEND_PORT=8000
BACKEND_HOST=0.0.0.0
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── FIREBASE SERVICE ACCOUNT (ENV-BASED) ────────────────────
# These values come from your Firebase service account JSON.
# ⚠️ No JSON file is used at runtime. Firestore only.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...your-key-here...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_CLIENT_ID=000000000000000000000

# ─── IOT SIMULATOR ───────────────────────────────────────────
IOT_SIMULATOR_BASE_URL=https://urban-simulator.onrender.com
IOT_SYNC_INTERVAL_SECONDS=60
IOT_SYSTEM_API_KEY=your-iot-system-api-key

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_PUBLIC=60
RATE_LIMIT_CITIZEN=100
RATE_LIMIT_ADMIN=200
RATE_LIMIT_IOT=300

# ─── LOGGING ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
